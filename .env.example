# ─── Приклад налаштувань для ВІРТУАЛЬНОГО тесту стратегії (paper-режим) ───
# Скопіюй у .env (локально) або встав як Environment Variables на Render.
# .env у git НЕ потрапляє (див. .gitignore).

# База даних (та сама, що й основний застосунок) — потрібна для збереження угод
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# ─── Режим ───
TRADE_MODE=paper                 # paper = віртуальні гроші на реальних цінах (БЕЗ ризику)
TRADE_PAPER_BALANCE=1000         # стартовий віртуальний депозит

# ─── Тип ринку ───
TRADE_MARKET_TYPE=spot           # spot (лише long) | swap (ф'ючерси: long+short, плече)
TRADE_LEVERAGE=1                 # плече (тільки для swap); обережно — підвищує ризик!
TRADE_ALLOW_SHORTS=false         # дозволити шорти (тільки swap) — заробляти й на падінні

# ─── Ринок ───
TRADE_EXCHANGE=binance           # будь-яка біржа ccxt
TRADE_SYMBOLS=BTC/USDT,ETH/USDT  # пари через кому
TRADE_TIMEFRAME=15m              # 15m — щоб угоди траплялися частіше для тесту
                                 # (1h/4h — спокійніше, але чекати довше)
TRADE_POLL_SECONDS=60            # як часто перевіряти ринок

# ─── Стратегія ───
TRADE_STRATEGY=ema_rsi           # ema_rsi | macd | bollinger | donchian
# Спільне (ATR для SL/TP):
TRADE_ATR_PERIOD=14
TRADE_ATR_SL_MULT=1.5            # стоп-лосс
TRADE_ATR_TP_MULT=3.0            # тейк-профіт
# Параметри ema_rsi:
TRADE_EMA_FAST=12
TRADE_EMA_SLOW=26
TRADE_RSI_PERIOD=14
TRADE_RSI_OVERBOUGHT=70
TRADE_RSI_OVERSOLD=30
# Параметри macd:
TRADE_MACD_FAST=12
TRADE_MACD_SLOW=26
TRADE_MACD_SIGNAL=9
# Параметри bollinger:
TRADE_BB_PERIOD=20
TRADE_BB_STD=2.0
# Параметри donchian:
TRADE_DONCHIAN_PERIOD=20

# ─── Ризик ───
TRADE_RISK_PER_TRADE=0.01        # 1% капіталу під ризиком на угоду
TRADE_MAX_POSITIONS=3
TRADE_MAX_DAILY_LOSS_PCT=0.05    # денний стоп: -5% → нові входи блокуються

# ─── Сповіщення в Telegram (необов'язково) ───
TRADE_NOTIFY=true
# TG_BOT_TOKEN=...
# TG_CHAT_ID=...

# ─── Реальні гроші (НЕ для тесту! вмикати свідомо й пізніше) ───
# TRADE_MODE=live
# TRADE_TESTNET=true
# TRADE_API_KEY=...
# TRADE_API_SECRET=...
